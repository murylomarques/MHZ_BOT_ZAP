# Bot (legado, em produção — não mexer na forma de uso)
DATABASE_URL=postgresql://user:password@host:6543/dbname?pgbouncer=true
WEBHOOK_VERIFY_TOKEN=defina-um-token-aleatorio-aqui
WHATSAPP_TOKEN=token-de-acesso-do-app-meta
WHATSAPP_PHONE_NUMBER_ID=id-do-numero-de-telefone-whatsapp

# Sistema novo (MHZ Retira)
# Conexão direta (sem pooler) usada só por migrations/introspecção do Prisma.
# No Supabase, mesmo host do DATABASE_URL, porta 5432 em vez de 6543.
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/dbname
# Segredo usado para assinar o cookie de sessão (JWT). Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Integração de mensageria em massa (HSM/Flow) — ainda sem credencial real,
# ver lib/server/providers/matrix-desktop-provider.ts (mock documentado).
MATRIX_DESKTOP_API_URL=
MATRIX_DESKTOP_API_TOKEN=
